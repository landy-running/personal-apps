{
  "name": "personal-apps-pwa-foundation",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:runos": "vite --config apps/runos-pwa/vite.config.ts",
    "dev:wanoku": "vite --config apps/wanoku-pwa/vite.config.ts",
    "build": "npm run typecheck && npm run build:runos && npm run build:wanoku && npm run build:runos-legacy",
    "build:runos": "vite build --config apps/runos-pwa/vite.config.ts",
    "build:wanoku": "vite build --config apps/wanoku-pwa/vite.config.ts",
    "build:runos-legacy": "node apps/runos-legacy-pwa/scripts/build.mjs",
    "preview:runos": "vite preview --config apps/runos-pwa/vite.config.ts",
    "preview:wanoku": "vite preview --config apps/wanoku-pwa/vite.config.ts",
    "preview:runos-legacy": "vite preview --outDir dist/runos-legacy-pwa",
    "worker:runos-strava:dev": "npx wrangler dev --config workers/runos-strava-worker/wrangler.toml",
    "worker:runos-strava:deploy": "npx wrangler deploy --config workers/runos-strava-worker/wrangler.toml",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "wrangler": "4.44.0"
  }
}
